# =============================================================================
# Smart Contract MCP — environment variables
# =============================================================================
# Copy this file to `.env.local` for local development and fill in real values:
#
#     cp env.example .env.local
#
# `.env` and `.env.local` are already excluded from version control by
# `.gitignore`. This file (`env.example`) is the safe, commit-able template.
#
# When the MCP server / REST endpoint is deployed to Vercel, set the same
# variables via the project's Environment Variables UI. None of the CYSIC_*
# keys are required for the project to build — the LLM-backed endpoints
# simply respond with a structured 503 / isError payload when the key is
# missing, so CI and offline builds keep working.
# =============================================================================


# -----------------------------------------------------------------------------
# Cysic LLM integration (`evaluate_quality` tool + `POST /api/evaluate`)
# -----------------------------------------------------------------------------
# These six variables configure the LLM-backed quality evaluation tool
# documented in `claude.md` under "LLM integration". They are read lazily
# by `lib/llm-client.ts` at request time, never at import time, so changing
# values requires only a server restart (not a rebuild).
#
# Where to get an API key:
#   The Cysic dashboard (https://token-ai.cysic.xyz/) issues bearer tokens
#   for the `minimax-m3` model. Paste the token below — it is never logged
#   and is redacted in any error message to its first 6 chars + "…".

# Required. Bearer token for the Cysic API. Leaving this empty disables the
# `evaluate_quality` MCP tool and `POST /api/evaluate` endpoint (they respond
# with `503 llm_not_configured` / an `isError: true` payload).
CYSIC_API_KEY=

# Optional. Base URL of the Cysic OpenAI-compatible API. The tool appends
# `/chat/completions` to this value at call time.
CYSIC_BASE_URL=https://token-ai.cysic.xyz/v1

# Optional. Model identifier passed in the OpenAI-style request body.
CYSIC_MODEL=minimax-m3

# Optional. Hard deadline (milliseconds) for a single LLM call. Enforced via
# `AbortController`. Past this, the call fails with `LlmUpstreamError`.
CYSIC_TIMEOUT_MS=30000

# Optional. Sampling temperature for the LLM. Lower = more deterministic.
CYSIC_TEMPERATURE=0.2

# Optional. Upper bound on completion tokens per response. Keep in sync with
# the QualityReport schema size.
CYSIC_MAX_TOKENS=2048
